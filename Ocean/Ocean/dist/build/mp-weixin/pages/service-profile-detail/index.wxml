<view class="detail-page"><scroll-view class="content" scroll-y="{{true}}" show-scrollbar="{{false}}"><view class="brand-card"><image class="brand-image" src="/static/images/beluge.png" mode="aspectFit"/><text class="brand-title">服务人员档案</text><text class="brand-sub">查看被服务人员的五感偏好</text></view><view wx:if="{{a}}" class="empty-card"><text class="empty-title">尚未绑定</text><text class="empty-desc">请在“寻找心青年”中输入邀请码进行绑定</text></view><view wx:else><view class="card"><text class="card-title">被服务人员</text><view class="field"><text class="label">姓名</text><text class="value">{{b}}</text></view><view class="field"><text class="label">年龄</text><text class="value">{{c}}</text></view><view class="field"><text class="label">邀请码</text><text class="value">{{d}}</text></view><view class="field multiline"><text class="label">自我介绍</text><text class="value">{{e}}</text></view></view><view class="card"><text class="card-title">五感雷达图</text><radar-chart wx:if="{{f}}" u-i="ccb1602e-0" bind:__l="__l" u-p="{{f}}"/></view><view class="card"><text class="card-title">游览注意事项</text><view wx:for="{{g}}" wx:for-item="tip" wx:key="c" class="tip-row"><uni-icons wx:if="{{h}}" u-i="{{tip.a}}" bind:__l="__l" u-p="{{h}}"></uni-icons><text class="tip-text">{{tip.b}}</text></view></view></view><view class="content-bottom-space"></view></scroll-view></view>