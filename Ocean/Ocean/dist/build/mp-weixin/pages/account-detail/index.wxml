<view class="account-detail-page"><scroll-view class="content" scroll-y="{{true}}" show-scrollbar="{{false}}"><view class="{{['card', i]}}"><view class="avatar-wrap" bindtap="{{b}}"><image class="avatar" src="{{a}}" mode="aspectFill"/></view><view class="card-body"><text class="card-label">昵称</text><input class="nickname-input" maxlength="12" placeholder="请输入昵称" value="{{c}}" bindinput="{{d}}"/><text class="card-label">身份</text><view class="role-switch"><view class="{{['role-btn', e && 'active']}}" bindtap="{{f}}">游客</view><view class="{{['role-btn', g && 'active']}}" bindtap="{{h}}">伴游</view></view></view></view><button class="save-btn" bindtap="{{j}}">保存</button></scroll-view></view>