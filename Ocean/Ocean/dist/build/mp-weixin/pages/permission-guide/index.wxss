.permission-page{height:100vh;background-color:#faf8f5;display:flex;flex-direction:column}.nav-header{height:44px;display:flex;align-items:center;padding:0 16px;margin-top:calc(env(safe-area-inset-top) + 6px)}.back-btn{width:32px;height:32px;display:flex;align-items:center;justify-content:center}.content{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:0 24px;padding-bottom:20vh}.illustration-placeholder{width:200rpx;height:200rpx;background-color:#c7b9e2;border-radius:50%;margin-bottom:24px}.title{font-size:20px;font-weight:700;margin-bottom:10px}.description{font-size:14px;color:#666;margin-bottom:22px}.allow-button{width:520rpx;max-width:520rpx;height:92rpx;line-height:92rpx;font-size:16px;background-color:#4d96a9;color:#fff;border-radius:46rpx}
