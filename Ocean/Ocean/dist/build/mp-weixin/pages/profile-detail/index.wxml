<view class="detail-page"><scroll-view class="content" scroll-y="{{true}}" show-scrollbar="{{false}}"><view class="user-info-card"><image class="avatar" src="{{a}}" mode="aspectFill"/><view class="info-content"><text class="user-id">ID: {{b}}</text><view class="user-tags"><text class="tag">{{c}}</text><text class="tag">{{d}}岁</text></view></view><view class="edit-btn" bindtap="{{f}}"><uni-icons wx:if="{{e}}" u-i="78ed98d1-0" bind:__l="__l" u-p="{{e}}"></uni-icons></view></view><view class="card"><text class="card-title">基本信息</text><view class="field"><text class="label">姓名</text><text class="value">{{g}}</text></view><view class="field"><text class="label">年龄</text><text class="value">{{h}} 岁</text></view><view class="field multiline"><text class="label">自我介绍</text><text class="value">{{i}}</text></view></view><view wx:if="{{j}}" class="card"><text class="card-title">测评结果</text><radar-chart wx:if="{{k}}" u-i="78ed98d1-1" bind:__l="__l" u-p="{{k}}"/></view><view wx:else class="card"><text class="card-title">感官测评</text><text class="card-desc">完成问卷后会生成你的五感雷达图，帮助我们提供更友好的游览建议。</text><button class="primary-btn" bindtap="{{l}}">填写问卷</button></view><view wx:if="{{m}}" class="card"><text class="card-title">重新测评</text><text class="card-desc">如需更新结果，可重新填写问卷。</text><button class="secondary-btn" bindtap="{{n}}">重新测评</button></view><view class="content-bottom-space"></view></scroll-view></view>