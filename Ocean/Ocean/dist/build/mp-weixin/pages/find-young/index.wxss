page{width:100%;height:100%;background-color:#f7f9f9}.find-page{min-height:100vh;padding:24rpx;box-sizing:border-box}.find-card{background-color:#faf8f5;border-radius:24rpx;padding:30rpx 24rpx}.card-title{display:block;font-size:34rpx;color:#2c3e50;font-weight:700}.card-sub{margin-top:12rpx;display:block;font-size:26rpx;color:rgba(44,62,80,.72)}.code-input{margin-top:20rpx;min-height:88rpx;border-radius:18rpx;background-color:rgba(44,62,80,.06);padding:0 20rpx;font-size:30rpx;color:#2c3e50}.code-placeholder{color:rgba(44,62,80,.45)}.bind-btn{margin-top:20rpx;width:100%;min-height:88rpx;border-radius:20rpx;border:none;background-color:#2a73ca;color:#fff;font-size:30rpx;display:flex;align-items:center;justify-content:center}.bind-btn:after{border:none}
