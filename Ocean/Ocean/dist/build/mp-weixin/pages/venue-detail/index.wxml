<view class="venue-detail-page"><scroll-view class="content" style="{{'height:' + p}}" scroll-y="{{true}}" show-scrollbar="{{false}}"><view class="section"><text class="section-title">{{a}}</text><image class="hero" src="{{b}}" mode="aspectFill"></image><text class="paragraph">{{c}}</text><text class="section-subtitle">感官友好度提醒</text><view wx:for="{{d}}" wx:for-item="sense" wx:key="d" class="sensory-row"><view class="sensory-bar"><view class="{{['sensory-fill', sense.a && 'warn']}}" style="{{'width:' + sense.b}}"></view></view><text class="sensory-label">{{sense.c}}</text></view><view class="tips-card"><text class="tips-title">Tips：</text><text class="tips-text">{{e}}</text></view><text class="section-subtitle">社交故事</text><swiper class="story-swiper" current="{{g}}" autoplay="{{false}}" bindchange="{{h}}"><swiper-item wx:for="{{f}}" wx:for-item="card" wx:key="d"><view class="story-card"><image class="story-card-image" src="{{card.a}}" mode="aspectFill"></image><view class="story-card-body"><text class="story-card-title">{{card.b}}</text><text class="story-card-text">{{card.c}}</text></view></view></swiper-item></swiper><view class="story-controls"><button class="story-nav prev" bindtap="{{i}}" disabled="{{j}}"><image class="story-nav-icon" src="/static/icons/chevron-left.png" mode="aspectFit"/></button><text class="story-progress">{{k}} / {{l}}</text><button class="story-nav next" bindtap="{{m}}" disabled="{{n}}"><image class="story-nav-icon" src="/static/icons/chevron-right.png" mode="aspectFit"/></button></view><text class="paragraph">{{o}}</text></view></scroll-view></view>